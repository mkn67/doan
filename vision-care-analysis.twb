    <datasource caption='Đánh Giá Khách Hàng - CSI (Vision Care)' inline='true' name='oracle.danh_gia' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='oracle.conn_danh_gia'>
            <connection authentication='RDBMS' class='oracle' one-time-sql='' port='1521' server='localhost' service='XEPDB1' sslmode='' username='KMY' />
          </named-connection>
        </named-connections>
        <relation connection='oracle.conn_danh_gia' name='Custom SQL Query' type='text'>SELECT 
              dg.MADG,
              dg.SO_SAO,
              dg.NOI_DUNG AS Y_KIEN_KHACH_HANG,
              dg.NGAY_DG AS THOI_GIAN_DANH_GIA,
              kh.HOTEN AS TEN_KHACH_HANG,
              ns.HOTEN AS TEN_BAC_SI_KHAM,
              hd.TONGTIEN AS GIA_TRI_DON_HANG
          FROM DANH_GIA dg
          JOIN KHACH_HANG kh ON dg.MAKH = kh.MAKH
          JOIN NHAN_SU ns ON dg.MANS = ns.MANS
          JOIN HO_SO_THI_LUC hs ON dg.MAHOSO = hs.MAHOSO
          LEFT JOIN HOA_DON hd ON hs.MAHOSO = hd.MAHOSO
          WHERE dg.IS_HIDDEN = 0</relation>
