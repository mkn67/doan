    <datasource caption='Hiệu Suất Xưởng Kính (Vision Care)' inline='true' name='oracle.xuly_kinh' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='oracle.conn_xuly_kinh'>
            <connection authentication='RDBMS' class='oracle' one-time-sql='' port='1521' server='localhost' service='XEPDB1' sslmode='' username='KMY' />
          </named-connection>
        </named-connections>
        <relation connection='oracle.conn_xuly_kinh' name='Custom SQL Query' type='text'><![CDATA[SELECT 
              xl.MAXL,
              xl.MADON,
              xl.TRANG_THAI AS TRANG_THAI_GIA_CONG,
              xl.NGAY_BAT_DAU,
              xl.NGAY_HOAN_THANH,
              ROUND((CAST(xl.NGAY_HOAN_THANH AS DATE) - CAST(xl.NGAY_BAT_DAU AS DATE)) * 24 * 60, 2) AS THOI_GIAN_GIA_CONG_PHUT,
              CASE 
                  WHEN (CAST(xl.NGAY_HOAN_THANH AS DATE) - CAST(xl.NGAY_BAT_DAU AS DATE)) * 24 * 60 <= 120 THEN 'Đúng hạn (dưới 2h)'
                  ELSE 'Trễ hạn (trên 2h)'
              END AS KPI_DUNG_HAN,
              ns.HOTEN AS TEN_KY_THUAT_VIEN,
              hd.MAHD,
              kh.HOTEN AS TEN_BENH_NHAN
          FROM XU_LY_KINH xl
          LEFT JOIN PHIEU_KE_DON pkd ON xl.MADON = pkd.MADON
          LEFT JOIN HOA_DON hd ON pkd.MADON = hd.MADON
          LEFT JOIN KHACH_HANG kh ON hd.MAKH = kh.MAKH
          LEFT JOIN NHAN_SU ns ON xl.MANS_KY_THUAT = ns.MANS
          WHERE xl.NGAY_BAT_DAU IS NOT NULL AND xl.NGAY_HOAN_THANH IS NOT NULL]]></relation>
        <metadata-records>
          <metadata-record class='column'>
            <remote-name>MAXL</remote-name>
            <remote-type>129</remote-type>
