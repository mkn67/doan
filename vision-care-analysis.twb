  <datasources>
    <datasource caption='Doanh Thu và Dòng Tiền (Vision Care)' inline='true' name='oracle.doanh_thu' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='oracle.conn_doanh_thu'>
            <connection authentication='RDBMS' class='oracle' one-time-sql='' port='1521' server='localhost' service='XEPDB1' sslmode='' username='KMY' />
          </named-connection>
        </named-connections>
        <relation connection='oracle.conn_doanh_thu' name='Custom SQL Query' type='text'>SELECT 
              hd.MAHD,
              hd.NGAYLAP AS NGAY_LAP_HD,
              TO_CHAR(hd.NGAYLAP, &apos;YYYY-MM&apos;) AS THANG_NAM,
              hd.TONGTIEN AS TONG_TIEN_HD,
              hd.TRANGTHAI AS TRANG_THAI_HD,
              kh.HOTEN AS TEN_KHACH_HANG,
              kh.GIOITINH AS GIOI_TINH_KH,
              kh.DIACHI AS DI_CHI_KH,
              ns.HOTEN AS TEN_THU_NGAN,
              tt.PHUONGTHUC AS PHUONG_THUC_THANH_TOAN,
              tt.NGAYTHANHTOAN AS THOI_GIAN_THANH_TOAN,
              tt.SOTIEN AS SO_TIEN_THANH_TOAN
          FROM HOA_DON hd
          LEFT JOIN KHACH_HANG kh ON hd.MAKH = kh.MAKH
          LEFT JOIN NHAN_SU ns ON hd.MANS = ns.MANS
          LEFT JOIN THANH_TOAN tt ON hd.MAHD = tt.MAHD
          WHERE hd.IS_DELETED = 0 AND hd.TRANGTHAI = N&apos;Đã thanh toán&apos;</relation>
