              xl.NGAY_BAT_DAU,
              xl.NGAY_HOAN_THANH,
              ROUND((CAST(xl.NGAY_HOAN_THANH AS DATE) - CAST(xl.NGAY_BAT_DAU AS DATE)) * 24 * 60, 2) AS THOI_GIAN_GIA_CONG_PHUT,
              CASE 
                  WHEN (CAST(xl.NGAY_HOAN_THANH AS DATE) - CAST(xl.NGAY_BAT_DAU AS DATE)) * 24 * 60 <= 120 THEN 'Đúng hạn (dưới 2h)'
                  ELSE 'Trễ hạn (trên 2h)'
              END AS KPI_DUNG_HAN,
              ns.HOTEN AS TEN_KY_THUAT_VIEN,
              hd.MAHD,
              kh.HOTEN AS TEN_BENH_NHAN
          FROM XU_LY_KINH xl
          LEFT JOIN PHIEU_KE_DON pkd ON xl.MADON = pkd.MADON
          LEFT JOIN HOA_DON hd ON pkd.MADON = hd.MADON
          LEFT JOIN KHACH_HANG kh ON hd.MAKH = kh.MAKH
          LEFT JOIN NHAN_SU ns ON xl.MANS_KY_THUAT = ns.MANS
          WHERE xl.NGAY_BAT_DAU IS NOT NULL AND xl.NGAY_HOAN_THANH IS NOT NULL]]></relation>
            </properties>
          </object>
        </objects>
      </object-graph>
    </datasource>
    <datasource caption='Tồn Kho và Lợi Nhuận (Vision Care)' inline='true' name='oracle.ton_kho' version='18.1'>
      <connection class='federated'>
        <named-connections>
          <named-connection caption='localhost' name='oracle.conn_ton_kho'>
            <connection authentication='RDBMS' class='oracle' one-time-sql='' port='1521' server='localhost' service='XEPDB1' sslmode='' username='KMY' />
          </named-connection>
        </named-connections>
        <relation connection='oracle.conn_ton_kho' name='Custom SQL Query' type='text'><![CDATA[SELECT 
              sp.MASP,
              sp.TENSP AS TEN_SAN_PHAM,
              lsp.TENLOAI AS LOAI_SAN_PHAM,
              lh.MALO AS MA_LO_HANG,
              lh.NGAYHETHAN AS NGAY_HET_HAN,
              CASE 
                  WHEN lh.NGAYHETHAN - TRUNC(SYSDATE) < 0 THEN 'Đã hết hạn'
                  WHEN lh.NGAYHETHAN - TRUNC(SYSDATE) BETWEEN 0 AND 90 THEN 'Cận hạn (dưới 3 tháng)'
                  ELSE 'An toàn'
              END AS TRANG_THAI_HSD,
              lh.SOLUONGNHAP,
              lh.SOLUONGTON,
              lh.GIANHAP,
              sp.GIABAN,
              (lh.SOLUONGNHAP - lh.SOLUONGTON) * sp.GIABAN AS DOANH_THU_THUC_TE,
              (lh.SOLUONGNHAP - lh.SOLUONGTON) * lh.GIANHAP AS CHI_PHI_VON_THUC_TE,
              ((lh.SOLUONGNHAP - lh.SOLUONGTON) * sp.GIABAN) - ((lh.SOLUONGNHAP - lh.SOLUONGTON) * lh.GIANHAP) AS LOI_NHUAN_THUC_TE
          FROM LO_HANG lh
          JOIN SAN_PHAM sp ON lh.MASP = sp.MASP
          JOIN LOAI_SAN_PHAM lsp ON sp.MALOAI = lsp.MALOAI]]></relation>
